# Bitwarden machine credentials for non-interactive vault access.
#
# The design rationale is in DISASTER_RECOVERY.md §ADR-001 (settled — do not
# re-litigate). Short version: agent/CI ergonomics require headless unlock;
# the master password held offline by the developer is the actual recovery seed.
#
# Setup:
#   cp .env.example .env
#   chmod 600 .env          # Linux/macOS
#   # Windows: icacls .env /inheritance:r /grant:r "%USERNAME%:(R)"
#   # Then fill in the three values below.
#
# API credentials: https://vault.bitwarden.com/#/settings/security/api-key
BW_CLIENTID=
BW_CLIENTSECRET=

# The vault master password. This is the DR seed — on a fresh machine with
# only this value you can log in interactively and recover every secret.
# Do NOT commit the filled-in .env. It is gitignored at **/.env.
BW_PASSWORD=
