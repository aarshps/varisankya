# Firebase Web SDK config for project "helloworld-92567418" (the SAME project
# the Android & iOS apps use). Get these values from:
#   Firebase Console → Project settings → General → Your apps → Web app
#   (register a Web app if one doesn't exist yet).
#
# These NEXT_PUBLIC_* values ship to the browser and are NOT secret — access is
# controlled by Firestore security rules keyed on the auth UID. Set the same
# values as Environment Variables in the Vercel project (Production + Preview).
#
# Copy this file to .env.local and fill in the values.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=helloworld-92567418.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=helloworld-92567418
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=helloworld-92567418.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=663138385072
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
